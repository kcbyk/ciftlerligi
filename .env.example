# Server
NODE_ENV=development
PORT=3000
ALLOWED_ORIGIN=*

SURVEY_JWT_SECRET=[SURVEY_JWT_SECRET]

# Firebase (choose one method)
# 1) Service account JSON file path
FIREBASE_SERVICE_ACCOUNT_PATH=[SERVICE_ACCOUNT_JSON_DOSYA_YOLU]

# 2) OR raw service account values
FIREBASE_PROJECT_ID=[FIREBASE_PROJECT_ID]
FIREBASE_CLIENT_EMAIL=[FIREBASE_CLIENT_EMAIL]
FIREBASE_PRIVATE_KEY="[FIREBASE_PRIVATE_KEY]"
FIREBASE_STORAGE_BUCKET=[FIREBASE_STORAGE_BUCKET]

# Telegram values
TELEGRAM_BOT_TOKEN=[TELEGRAM_BOT_TOKEN]
TELEGRAM_CHAT_ID=[TELEGRAM_CHAT_ID]
APP_BASE_URL=[SITE_URL]
TELEGRAM_WEBHOOK_SECRET=[TELEGRAM_WEBHOOK_SECRET]
TELEGRAM_POLLING_ENABLED=true
